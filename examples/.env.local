# Local development environment
APP_NAME=envx
APP_ENV=local
APP_PORT=8080
APP_DEBUG=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=envx_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Cache
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
SECRET_KEY=dev-secret-key-not-for-production
JWT_SECRET=dev-jwt-secret

# Feature flags
FEATURE_DARK_MODE=true
FEATURE_BETA_API=true

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty
